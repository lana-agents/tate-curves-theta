import Mathlib

/-!
# The Tate analytic quotient `Kň£ / qŠ∂Ľ`

This file records the first, purely group-theoretic, layer of Tate's
`q`-uniformization of an elliptic curve with split multiplicative reduction.

Fix a complete nonarchimedean field `K` (here modelled by a `NormedField`) and a
*Tate parameter* `q ‚ąą Kň£` with `0 < ‚ÄĖq‚ÄĖ < 1`.  Multiplication by `q` generates a
cyclic subgroup `qŠ∂Ľ ‚Č§ Kň£`, and the analytic torus underlying the Tate curve is the
quotient group `Kň£ / qŠ∂Ľ`.

We package the datum, show that `q` has infinite (multiplicative) order ‚ÄĒ so `qŠ∂Ľ`
is a free abelian group of rank one ‚ÄĒ and introduce the quotient `Kň£ / qŠ∂Ľ` as a
commutative group.

The Weierstrass model `E_q`, the group isomorphism `Kň£ / qŠ∂Ľ ‚ČÉ E_q(K)`, and
functoriality under complete field extensions are developed on top of this file.

## Main definitions

* `TateCurvesTheta.TateDatum` : a unit `q` of a normed field with `‚ÄĖq‚ÄĖ < 1`.
* `TateDatum.qpowers` : the subgroup `qŠ∂Ľ ‚Č§ Kň£`.
* `TateDatum.AnalyticQuotient` : the group `Kň£ / qŠ∂Ľ`.

## Main results

* `TateDatum.q_zpow_injective` : `n ‚Ü¶ q‚ĀŅ` is injective, i.e. `q` has infinite order.
* `TateDatum.qpowers_infinite` : `qŠ∂Ľ` is infinite.

## References

* J. Tate, *A review of non-Archimedean elliptic functions*.
* J. Silverman, *Advanced Topics in the Arithmetic of Elliptic Curves*, Chapter V.
-/

namespace TateCurvesTheta

/-- A **Tate datum** over a normed field `K`: a unit `q` whose norm is strictly less
than one.  This is the archetype of the multiplicative parameter of a Tate elliptic
curve with split multiplicative reduction. -/
structure TateDatum (K : Type*) [NormedField K] where
  /-- The Tate parameter, a unit of `K`. -/
  q : Kň£
  /-- The defining smallness condition `‚ÄĖq‚ÄĖ < 1`. -/
  norm_q_lt_one : ‚ÄĖ(q : K)‚ÄĖ < 1

namespace TateDatum

variable {K : Type*} [NormedField K] (T : TateDatum K)

/-- The norm of the Tate parameter is strictly positive. -/
lemma norm_q_pos : 0 < ‚ÄĖ(T.q : K)‚ÄĖ :=
  norm_pos_iff.mpr T.q.ne_zero

/-- The norm of the Tate parameter is nonzero. -/
lemma norm_q_ne_zero : ‚ÄĖ(T.q : K)‚ÄĖ ‚Č† 0 :=
  T.norm_q_pos.ne'

/-- The Tate parameter is not equal to one, since its norm is `< 1` while `‚ÄĖ1‚ÄĖ = 1`. -/
lemma q_ne_one : T.q ‚Č† 1 := by
  intro h
  have : ‚ÄĖ(T.q : K)‚ÄĖ = 1 := by rw [h]; simp
  exact absurd this (by simpa using T.norm_q_lt_one.ne)

/-- The norm of an integer power of `q` is the corresponding power of `‚ÄĖq‚ÄĖ`. -/
lemma norm_val_zpow (n : ‚Ą§) : ‚ÄĖ((T.q ^ n : Kň£) : K)‚ÄĖ = ‚ÄĖ(T.q : K)‚ÄĖ ^ n := by
  rw [Units.val_zpow_eq_zpow_val, norm_zpow]

/-- The map `n ‚Ü¶ q‚ĀŅ` from `‚Ą§` to `Kň£` is injective: `q` has infinite multiplicative
order.  Distinct integer powers of `q` have distinct norms because `0 < ‚ÄĖq‚ÄĖ < 1`. -/
lemma q_zpow_injective : Function.Injective (fun n : ‚Ą§ => T.q ^ n) := by
  intro m n h
  have hnorm : ‚ÄĖ(T.q : K)‚ÄĖ ^ m = ‚ÄĖ(T.q : K)‚ÄĖ ^ n := by
    have := congrArg (fun u : Kň£ => ‚ÄĖ(u : K)‚ÄĖ) h
    simpa only [norm_val_zpow] using this
  exact zpow_right_injective‚āÄ T.norm_q_pos T.norm_q_lt_one.ne hnorm

/-- The subgroup `qŠ∂Ľ ‚Č§ Kň£` generated by the Tate parameter. -/
def qpowers : Subgroup Kň£ := Subgroup.zpowers T.q

@[simp] lemma q_mem_qpowers : T.q ‚ąą T.qpowers := Subgroup.mem_zpowers T.q

/-- The subgroup `qŠ∂Ľ` is infinite: it is the image of the injective map `n ‚Ü¶ q‚ĀŅ`. -/
lemma qpowers_infinite : (T.qpowers : Set Kň£).Infinite := by
  apply Set.infinite_coe_iff.mp
  refine Set.infinite_coe_iff.mpr ?_
  have : Set.range (fun n : ‚Ą§ => T.q ^ n) ‚äÜ (T.qpowers : Set Kň£) := by
    rintro _ ‚ü®n, rfl‚ü©
    exact Subgroup.zpow_mem _ (Subgroup.mem_zpowers _) n
  exact (Set.infinite_range_of_injective T.q_zpow_injective).mono this

/-- The **Tate analytic quotient** `Kň£ / qŠ∂Ľ`.  This commutative group is the group of
`K`-points of the Tate curve `E_q`. -/
abbrev AnalyticQuotient := Kň£ ‚ßł T.qpowers

/-- The natural projection `Kň£ ‚Üí Kň£ / qŠ∂Ľ`. -/
abbrev toAnalyticQuotient : Kň£ ‚Üí* T.AnalyticQuotient := QuotientGroup.mk' T.qpowers

/-- The Tate parameter maps to the identity in the analytic quotient. -/
@[simp] lemma toAnalyticQuotient_q : T.toAnalyticQuotient T.q = 1 := by
  rw [QuotientGroup.mk'_apply, QuotientGroup.eq_one_iff]
  exact T.q_mem_qpowers

end TateDatum

end TateCurvesTheta
